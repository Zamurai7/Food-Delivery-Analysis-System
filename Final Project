# 4. Server

server <- function(input, output) {
  
  # Read data
  raw_data <- reactive({
    req(input$file1) 
    # Prevent the app from stopping if the file is corrupted
    tryCatch({
      read.csv(input$file1$datapath, stringsAsFactors = FALSE)
    }, error = function(e) {
      return(NULL)
    })
  })
  
  # Data Preview
  output$data_preview <- DT::renderDT({
    req(raw_data()) 
    raw_data()
  }, options = list(scrollX = TRUE, pageLength = 5))
  
  # Analyses
  analyses <- eventReactive(input$run_all, {
    req(raw_data()) 
    df <- raw_data()
    
    # Make sure data isn't empty
    validate(need(nrow(df) > 0, "File is empty!"))
    
    # 1. Preparing the rules
    df_rules <- df %>% mutate(
      Distance_features = case_when(Distance_km < 5 ~ "Short", Distance_km < 10 ~ "Medium", TRUE ~ "Long"),
      Preparation_Time_features = case_when(Preparation_Time_min < 10 ~ "Fast", Preparation_Time_min < 20 ~ "Medium", TRUE ~ "Slow"),
      Courier_Experience_features = case_when(Courier_Experience_yrs < 2 ~ "New", Courier_Experience_yrs < 5 ~ "Exp", TRUE ~ "Veteran")
    )
    
    # 2. Association Rules
    rules_res <- association_logic_arules(df_rules, input$support, input$maxlen)
    
    # 3. K-means
    kmeans_res <- kmeans_logic(df, input$clusters, 10, input$iterations)
    
    list(rules = rules_res, kmeans = kmeans_res)
  })
  
  # Export
  output$download_clusters <- downloadHandler(
    filename = function() { paste("Clustered_Data_", Sys.Date(), ".csv", sep = "") },
    content = function(file) {
      req(analyses())
      write.csv(analyses()$kmeans$data, file, row.names = FALSE)
    }
  )
  
  output$download_rules <- downloadHandler(
    filename = function() { paste("Rules_Table_", Sys.Date(), ".csv", sep = "") },
    content = function(file) {
      req(analyses())
      write.csv(analyses()$rules, file, row.names = FALSE)
    }
  )
  
  # Static plots
  output$plot1_hist <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Delivery_Time_min)) + geom_histogram(bins=30, fill = "#1f77b4", alpha = 0.8) + theme_minimal() })
  output$plot2_traffic <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Traffic_Level, fill = Traffic_Level)) + geom_bar() + theme_minimal() })
  output$plot3_dist <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Distance_km, y = Delivery_Time_min)) + geom_point(alpha = 0.6) + geom_smooth(method = "lm") + theme_minimal() })
  output$plot4_weather <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Weather, y = Delivery_Time_min, fill = Weather)) + geom_boxplot() + theme_minimal() })
  output$plot5_traffic_box <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Traffic_Level, y = Delivery_Time_min, fill = Traffic_Level)) + geom_boxplot() + theme_minimal() })
  output$plot6_vehicle <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Vehicle_Type, y = Delivery_Time_min, fill = Vehicle_Type)) + geom_boxplot() + theme_minimal() })
  output$plot7_exp <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Courier_Experience_yrs, y = Delivery_Time_min)) + geom_point() + theme_minimal() })
  output$plot8_late <- renderPlot({ req(raw_data()); ggplot(raw_data(), aes(x = Late_Delivery_Flag, y = Delivery_Time_min, fill = Late_Delivery_Flag)) + geom_boxplot() + theme_minimal() })
  
  # 3D plots
  output$plot_3d <- renderPlotly({
    req(input$run_all)
    plot_ly(raw_data(), x = ~Distance_km, y = ~Preparation_Time_min, z = ~Delivery_Time_min, 
            color = ~Late_Delivery_Flag, colors = c('#FF0000', '#00CC00'), size = 3) %>%
      add_markers()
  })
  
  # Dynamic plots
  output$dynamic_weather <- renderEcharts4r({
    req(input$run_all)
    raw_data() %>% group_by(Weather) %>% summarise(Count = n()) %>% 
      e_charts(Weather) %>% e_bar(Count) %>% e_tooltip()
  })
  
  output$dynamic_gauge <- renderEcharts4r({
    req(input$run_all)
    avg_speed <- round(mean(raw_data()$speed, na.rm=TRUE) * 10, 1)
    e_charts() %>% e_gauge(avg_speed, "Avg Speed")
  })
  
  output$dynamic_line <- renderEcharts4r({
    req(input$run_all)
    raw_data() %>% group_by(Time_of_Day) %>% summarise(Avg_Time = mean(Delivery_Time_min)) %>%
      e_charts(Time_of_Day) %>% e_line(Avg_Time) %>% e_tooltip()
  })
  
  # Outputs
  output$kmeans_plot <- renderPlot({ 
    req(analyses())
    res <- analyses()$kmeans
    fviz_cluster(res$model, data = res$data %>% select(-Cluster), geom = "point") 
  })
  
  output$kmeans_centers <- renderTable({ 
    req(analyses())
    analyses()$kmeans$centers 
  }, rownames = TRUE)
  
  output$rules_table <- renderTable({ 
    req(analyses())
    analyses()$rules 
  }, digits = 3)
  
  output$rules_text <- renderPrint({
    req(analyses())
    rules <- analyses()$rules
    
    # Loading bar
    validate(need(is.data.frame(rules), "Please Wait 🛺..."))
    
    # Organize arules
    if (nrow(rules) > 0) {
      top <- utils::head(rules, 10)
      for (i in 1:nrow(top)) { cat(sprintf("Rule #%d: IF [%s] THEN Late (Lift: %.2f)\n", i, top[i, "LHS"], top[i, "Lift"])) }
    } else { 
      cat("No strong rules found with current support/confidence levels.") 
    }
  })
}

shinyApp(ui, server)