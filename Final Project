# 2. Define algorithm functions (Backend Logic)

# (A) Association Rules
association_logic_arules <- function(df, min_support, max_len) {
  
  # Convert data into transactions
  df_trans <- df %>% mutate(across(everything(), as.factor))
  trans <- as(df_trans, "transactions")
  
  # Apriori
  rules <- apriori(trans, 
                   parameter = list(supp = min_support, 
                                    conf = 0.1, 
                                    maxlen = max_len, 
                                    minlen = 2),
                   control = list(verbose = FALSE)) # Turns off the progress messages that the algorithm would otherwise print while it runs
  
  # Filtering Results
  target_rule <- "Late_Delivery_Flag=late"
  
  if (length(rules) == 0) return(data.frame())
  
  rules_late <- subset(rules, rhs %in% target_rule) # subtracts the rules that achieve the condition only
  
  if (length(rules_late) > 0) {
    # Convert the rules object to a data frame
    res_df <- as(rules_late, "data.frame") 
    
    # Cleaning " LHS => RHS "
    res_df$rules <- as.character(res_df$rules) 
    parts <- strsplit(res_df$rules, " => ")
    
    res_df$LHS <- sapply(parts, "[", 1) 
    res_df$RHS <- "Late Delivery"       
    
    # Organize results
    res_df <- res_df %>% # Pick and rename the columns to a clean output and keep only rules with Lift > 1
      select(LHS, RHS, support, confidence, lift) %>%
      rename(Support = support, Confidence = confidence, Lift = lift) %>%
      filter(Lift > 1) %>%        
      arrange(desc(Lift)) # Arrange in descending order       
    
    return(res_df)
  } else {
    return(data.frame()) 
  }
}

# (B) K-means
kmeans_logic <- function(df, k, nstart, max_iter) {
  # Choosing the numeric columns
  numeric_cols <- df %>% 
    select(Distance_km, Preparation_Time_min, Courier_Experience_yrs, Delivery_Time_min, speed) %>%      
    na.omit()
  
  # Scale Data
  scaled_data <- scale(numeric_cols)
  
  set.seed(123)
  
  # Run K-means
  km_result <- kmeans(scaled_data, centers = k, nstart = nstart, iter.max = max_iter)
  
  # Adding resutls 
  numeric_cols$Cluster <- as.factor(km_result$cluster)
  
  return(list(model = km_result, data = numeric_cols, centers = km_result$centers))
}

